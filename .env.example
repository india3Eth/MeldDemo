# =============================================================================
# Meld White-Label API Configuration
# =============================================================================
# Get your API keys from the Meld Dashboard: https://dashboard.meld.io
#
# MELD_API_KEY        — Your Meld API key (used in Authorization header)
# MELD_API_BASE_URL   — Base URL for the Meld API
#                        Sandbox:    https://api-sb.meld.io
#                        Production: https://api.meld.io
# MELD_API_VERSION    — API version header (e.g., 2026-02-03)
# MELD_WEBHOOK_SECRET — Secret for verifying webhook signatures (HMAC-SHA256)
# =============================================================================

MELD_API_KEY=
MELD_API_BASE_URL=https://api-sb.meld.io
MELD_API_VERSION=2026-02-03
MELD_WEBHOOK_SECRET=

# =============================================================================
# Supabase — used for real-time transaction status tracking
# =============================================================================
# Create a project at https://supabase.com
# Settings → API → Project URL + API Keys (Publishable + Secret)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
